FROM python:3.12-slim

WORKDIR /app

# UI chỉ cần streamlit + requests để gọi API qua HTTP
# Không cần torch, sentence-transformers, fastembed... → build ~60s thay vì ~20 phút
RUN pip install --no-cache-dir streamlit requests python-dotenv

COPY . .

EXPOSE 8501

CMD ["streamlit", "run", "src/api/streamlit_app.py", "--server.address=0.0.0.0"]